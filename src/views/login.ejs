<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/login.css" />
    <%- include('partials/links') %>
    <title><%= title %> | MP Payments</title>
  </head>
  <body>
    <div class="sidenav">
      <div class="login-main-text">
        <h2>App Mercado Pago Payments</h2>

        <hr class="border border-light border-2 opacity-85" />

        <p>Mercado Pago Payments</p>

        <p>Ingresa tus credenciales para ingresar</p>
      </div>
    </div>
    <div class="main">
      <div class="col-md-6 col-sm-12">
        <div class="login-form">
          <form method="post" action="/auth/login">
            <div class="form-group">
              <label class="form-label">Usuario</label>
              <input type="text" name="username" class="form-control" />
            </div>
            <div class="form-group pass">
              <label class="form-label">Contraseña</label>

              <input
                class="form-control"
                name="password"
                type="password"
                id="password"
              />

              <i class="bi bi-eye-slash" id="show_hide_password"></i>
            </div>

            <button type="submit" class="btn btn-outline-info mt-4 login-btn">
              Login
            </button>
          </form>
        </div>
      </div>
    </div>
  </body>

  <script src="/js/toggle-pass.js"></script>
</html>
